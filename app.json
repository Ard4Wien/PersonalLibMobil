{
  "expo": {
    "name": "PersonalLib",
    "slug": "personal-lib-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "personallibmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/splash-icon.png",
      "color": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ardaw.personallibmobile",
      "infoPlist": {
        "NSNotificationsUsageDescription": "PersonalLib, hazırladığınız okuma ve izleme listeleriniz için size hatırlatıcılar göndermek üzere bildirim izni ister."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D81B60",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ardaw.personallibmobile"
    },
    "updates": {
      "url": "https://u.expo.dev/26d80408-16ad-458e-b0ea-3adb958ac257"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-notifications",
        {
          "autoServerRegistration": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090b",
          "dark": {
            "backgroundColor": "#09090b"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26d80408-16ad-458e-b0ea-3adb958ac257"
      }
    }
  }
}